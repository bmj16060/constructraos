{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": ["completed", "blocked", "failed"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "recommended_next_agent": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": ["status", "summary", "recommended_next_agent"],
  "additionalProperties": false
}
